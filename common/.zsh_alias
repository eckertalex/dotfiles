#!/bin/zsh
#
# .zsh_alias - Zsh aliases
#

#######
# Basic
#######

alias zbench="for i in {1..10}; do; /usr/bin/time $SHELL -lic exit; done"
alias hbench="hyperfine --warmup 3 \"$SHELL -lic exit\""

alias shellclean="rm -rf ~/.local/share/zsh/zcompdump* ~/.local/share/zsh/plugins"

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

alias nuke-ds-store="find . -type f -name '*.DS_Store' -ls -delete"

alias print-fpath='for fp in $fpath; do echo $fp; done; unset fp'
alias print-path='echo $PATH | tr ":" "\n"'
alias hstat="history 0 | awk '{print \$2}' | sort | uniq -c | sort -n -r | head"

#########
# lazygit
#########

if (( $+commands[lazygit] )); then
	alias lazygit="lazygit --use-config-dir=\"$XDG_CONFIG_HOME/lazygit\""
	alias lzg="lazygit --use-config-dir=\"$XDG_CONFIG_HOME/lazygit\""
fi

#######
# utils
#######

alias cp="cp -vi"
alias mv="mv -vi"
alias rm="rm -vI"
alias mkdir="mkdir -pv"
alias grep="grep --color=auto"
if (( $+commands[gsed] )); then
	alias sed="gsed"
fi

##########
# Homebrew
##########

if (( $+commands[brew] )); then
	alias brewup="brew update && brew bundle --global && brew upgrade && brew cleanup"
	alias brewinfo="brew leaves | xargs brew desc --eval-all"
fi

####
# ls
####

if (( $+commands[gls] )); then
	alias ls="gls -vAF --color --group-directories-first"
else
	alias ls="ls -vAF --color --group-directories-first"
fi
alias ll="ls -lh"

######
# tree
######

alias tree="tree -Fav -I '.git' --dirsfirst"

#####
# git
#####

alias g=git

# Mirror every `git` alias as a `g`-prefixed shell alias, cached and only
# rebuilt when the git alias file changes.
() {
	local cache="$XDG_CACHE_HOME/zsh-git-aliases"
	local gitalias="${XDG_CONFIG_HOME:-$HOME/.config}/git/alias"
	if [[ ! -r "$cache" || "$gitalias" -nt "$cache" ]]; then
		mkdir -p "${cache:h}"
		local al
		for al in $(git --list-cmds=alias 2>/dev/null); do
			print -- "alias g$al=\"git $al\""
		done > "$cache"
	fi
	source "$cache"
}

# vim: set ts=4 sw=4
