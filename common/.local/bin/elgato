#!/usr/bin/env bash

# Toggle Elgato Keylights on or off.
# Usage: elgato <on|off>

set -euo pipefail

if [[ "$1" == "" ]]; then
	echo "Usage: $(basename "$0") <on|off>" >&2
	exit 2
fi

# To discover addresses, resolve mDNS type _elg._tcp, e.g.:
#   avahi-browse -t _elg._tcp --resolve
# left: 192.168.2.164
# right: 192.168.2.165
ELGATO_LIGHTS=192.168.2.164:9123,192.168.2.165:9123

function lights() {
	host=$1
	if [[ "$2" == "on" ]]; then
		on=1
	else
		on=0
	fi
	curl --silent "http://$host/elgato/lights" -XPUT -H 'Content-Type: application/json' -d '{"numberOfLights":1,"lights":[{"on":'$on'}]}' >/dev/null
}

IFS=',' read -r -a array <<<"$ELGATO_LIGHTS"

if [[ "$1" == "on" ]]; then
	echo "Turning all lights on"
else
	echo "Turning all lights off"
fi
for light in "${array[@]}"; do
	lights "$light" "$1"
done
