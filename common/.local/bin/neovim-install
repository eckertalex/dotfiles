#!/usr/bin/env bash

# Install or update Neovim from GitHub releases.
# Supports macOS arm64 and Linux x86_64 (Fedora).
# Installs to ~/.local/share/nvim-bin and symlinks
# the binary to ~/.local/bin/nvim.
# Keeps an install log at ~/.local/share/nvim-bin/install.log.
#
# Usage:
#   neovim-install           # installs stable (default)
#   neovim-install nightly   # installs nightly
#   neovim-install v0.10.3   # installs a specific version

set -euo pipefail

OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS/$ARCH" in
  Darwin/arm64)
    TARBALL="nvim-macos-arm64.tar.gz"
    MACOS=true
    ;;
  Linux/x86_64)
    TARBALL="nvim-linux-x86_64.tar.gz"
    MACOS=false
    ;;
  *)
    echo "Error: unsupported platform $OS/$ARCH" >&2
    echo "Supported: macOS arm64, Linux x86_64" >&2
    exit 1
    ;;
esac


CHANNEL="${1:-stable}"

case "$CHANNEL" in
  nightly|stable) ;;
  v[0-9]*) ;;
  *)
    echo "Usage: neovim-install [nightly|stable|v<version>]" >&2
    echo "  neovim-install            # stable (default)" >&2
    echo "  neovim-install nightly    # nightly" >&2
    echo "  neovim-install v0.10.3    # specific version" >&2
    exit 1
    ;;
esac

DOWNLOAD_URL="https://github.com/neovim/neovim/releases/download/$CHANNEL/$TARBALL"
INSTALL_DIR="$HOME/.local/share/nvim-bin"
BIN_DIR="$HOME/.local/bin"
TAR_FILE="/tmp/$TARBALL"

# Show current version if installed
if [[ -x "$INSTALL_DIR/bin/nvim" ]]; then
  echo "Current: $("$INSTALL_DIR/bin/nvim" --version | head -1)"
else
  echo "No existing Neovim installation found"
fi

echo "Downloading $CHANNEL from GitHub..."
curl -fsSL "$DOWNLOAD_URL" -o "$TAR_FILE"

# macOS quarantine flag prevents unsigned binaries from running
if [[ "$MACOS" == true ]]; then
  xattr -c "$TAR_FILE"
fi

echo "Installing to $INSTALL_DIR..."
# Preserve install log across reinstalls
INSTALL_LOG="$INSTALL_DIR/install.log"
[[ -f "$INSTALL_LOG" ]] && cp "$INSTALL_LOG" /tmp/nvim-install.log
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
[[ -f /tmp/nvim-install.log ]] && mv /tmp/nvim-install.log "$INSTALL_LOG"
tar xzf "$TAR_FILE" -C "$INSTALL_DIR" --strip-components=1

mkdir -p "$BIN_DIR"
ln -sf "$INSTALL_DIR/bin/nvim" "$BIN_DIR/nvim"

rm -f "$TAR_FILE"

VERSION="$("$INSTALL_DIR/bin/nvim" --version | head -1)"
echo "$(date +%Y-%m-%d) $VERSION ($CHANNEL)" >> "$INSTALL_DIR/install.log"

echo "Installed: $VERSION"
