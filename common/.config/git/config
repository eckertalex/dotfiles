[branch]
	sort = -committerdate
[column]
	ui = auto
[commit]
	template = ~/.config/git/message
	verbose = true
[core]
	editor = nvim
	fsmonitor = true
	pager = delta
	untrackedCache = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[help]
	autocorrect = prompt
[include]
	path = ~/.config/git/alias
	path = ~/.config/git/local
[includeIf "gitdir:~/.dotfiles/"]
	path = ~/.config/git/private
[includeIf "gitdir:~/.dotwork/"]
	path = ~/.config/git/private
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[diff]
    tool = nvimdiff
	algorithm = histogram
	colorMoved = default
	mnemonicPrefix = true
	renames = true
[merge]
    tool = nvimdiff
	ff = only
	conflictstyle = zdiff3
[mergetool]
	keepBackup = false
[mergetool "nvimdiff"]
    cmd = nvim -f -c 'Gvdiffsplit!' $MERGED
[pull]
	rebase = true
[push]
	default = simple
	autoSetupRemote = true
	followTags = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[rerere]
	autoupdate = true
	enabled = true
[tag]
	sort = version:refname
[delta]
	light = true
	hyperlinks = true
	line-numbers = true
	navigate = true
	syntax-theme = "rose-pine-dawn"

