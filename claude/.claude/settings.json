{
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "autoMemoryEnabled": false,
    "permissions": {
        "allow": ["Read(~/code/work/*)", "Write(~/code/work/*)"],
        "deny": [
            "Read(~/.ssh/)",
            "Read(~/.aws/)",
            "Read(./.env)",
            "Read(./.env.*)",
            "Edit(./.env)",
            "Edit(./.env.*)"
        ]
    },
    "model": "opus[1m]",
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh"
    }
}
